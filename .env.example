# Application
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/centralhub?schema=public"

# JWT
JWT_SECRET=tu-super-secret-jwt-key-cambiar-en-produccion
JWT_REFRESH_SECRET=tu-super-secret-refresh-key-cambiar-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
